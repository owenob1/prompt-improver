  "model_backend_patterns": [
    {
      "patterns": [
        "mythos*",
        "fable*",
        "claude-*",
        "sonnet*",
        "haiku*",
        "opus*",
        "claude"
      ],
      "backend": "claude"
    },
    {
      "patterns": [
        "grok*",
        "composer*",
        "spacex*"
      ],
      "backend": "grok"
    },
    {
      "patterns": [
        "gemini*"
      ],
      "backend": "gemini"
    },
    {
      "patterns": [
        "gpt-*",
        "gpt*",
        "o1*",
        "o3*",
        "o4*",
        "codex",
        "codex*",
        "openai",
        "chatgpt*",
        "sol",
        "terra",
        "luna"
      ],
      "backend": "codex"
    }
  ],
  "model_fallback_chains": [
    {
      "patterns": [
        "*mythos*",
        "mythos"
      ],
      "chain": [
        "claude-mythos-5",
        "claude-mythos-preview",
        "claude-fable-5",
        "fable",
        "opus",
        "sonnet"
      ]
    },
    {
      "patterns": [
        "*fable*",
        "fable"
      ],
      "chain": [
        "claude-fable-5",
        "fable",
        "opus",
        "sonnet"
      ]
    },
    {
      "patterns": [
        "*opus*",
        "opus"
      ],
      "chain": [
        "opus",
        "sonnet"
      ]
    },
    {
      "patterns": [
        "*sonnet*",
        "sonnet"
      ],
      "chain": [
        "$primary",
        "sonnet"
      ]
    },
    {
      "patterns": [
        "*haiku*",
        "haiku"
      ],
      "chain": [
        "$primary",
        "haiku",
        "sonnet"
      ]
    },
    {
      "patterns": [
        "*sol*",
        "gpt-5.6"
      ],
      "chain": [
        "gpt-5.6-sol",
        "gpt-5.6-terra",
        "gpt-5.6-luna",
        "gpt-5.5"
      ]
    },
    {
      "patterns": [
        "*terra*"
      ],
      "chain": [
        "gpt-5.6-terra",
        "gpt-5.6-luna",
        "gpt-5.5"
      ]
    },
    {
      "patterns": [
        "*luna*"
      ],
      "chain": [
        "gpt-5.6-luna",
        "gpt-5.5"
      ]
    },
    {
      "patterns": [
        "gpt-5.5",
        "gpt-5",
        "codex",
        "openai"
      ],
      "chain": [
        "gpt-5.5"
      ]
    },
    {
      "patterns": [
        "grok-4.5",
        "grok-4*"
      ],
      "chain": [
        "grok-4.5",
        "grok-composer-2.5-fast",
        "grok-build"
      ]
    },
    {
      "patterns": [
        "*composer*"
      ],
      "chain": [
        "$primary",
        "grok-composer-2.5-fast"
      ]
    },
    {
      "patterns": [
        "*gemini*pro*",
        "gemini-2.5-pro"
      ],
      "chain": [
        "gemini-2.5-pro",
        "gemini-2.5-flash"
      ]
    },
    {
      "patterns": [
        "*gemini*flash*",
        "gemini-2.5-flash"
      ],
      "chain": [
        "gemini-2.5-flash"
      ]
    }
  ],
  "supported_backends": [
    "claude",
    "grok",
    "gemini",
    "codex",
    "cline",
    "opencode",
    "kimi",
    "kiro"
  ],
  "backend_commands": {
    "grok": "grok -p \"$(cat \"{prompt_file}\")\" {model_args} --output-format plain --yolo",
    "claude": "claude -p \"$(cat \"{prompt_file}\")\" --print {model_args}",
    "gemini": "gemini -p \"$(cat \"{prompt_file}\")\" {model_args}",
    "cline": "cline --prompt \"$(cat \"{prompt_file}\")\" --headless {model_args}",
    "opencode": "opencode -p \"$(cat \"{prompt_file}\")\" {model_args}",
    "kimi": "kimi \"$(cat \"{prompt_file}\")\" --headless {model_args}",
    "kiro": "kiro -p \"$(cat \"{prompt_file}\")\" {model_args}",
    "codex": "codex exec \"$(cat \"{prompt_file}\")\" {model_args}",
    "openai": "codex exec \"$(cat \"{prompt_file}\")\" {model_args}"
  },
  "backend_model_flags": {
    "grok": "-m {model}",
    "claude": "--model {model}",
    "gemini": "-m {model}",
    "codex": "-m {model}",
    "openai": "-m {model}",
    "cline": "",
    "opencode": "",
    "kimi": "",
    "kiro": ""
  },
  "limit_detection": {
    "account_patterns": "weekly.?limit|monthly.?limit|hit your .*limit|you.?ve hit your|you have hit your|organization.?limit|org.?limit|account.?limit|out of (usage|credits)|usage.?limit.?reached|limit \u00b7 resets|limit \u00b7 reset",
    "retry_patterns": "rate.?limit|usage.?limit|quota|out of (limit|usage|credits)|capacity|overloaded|529|429|403|401|not (available|found|supported|enabled)|unknown model|invalid model|model .* (denied|restricted|not accessible)|access denied|does not have access|invitation|glasswing|unavailable|try again later|too many requests|resource.?exhausted|throttl",
    "xml_markers": "<task[[:space:]]>|<prompt[[:space:]]>|<verification[[:space:]>]>"
  },
  "host_env_markers": {
    "claude": [
      "CLAUDE_CODE",
      "CLAUDECODE",
      "CLAUDE_CODE_ENTRYPOINT",
      "CLAUDE_AGENT"
    ],
    "grok": [
      "GROK_BUILD",
      "XAI_GROK",
      "GROK_SESSION"
    ],
    "gemini": [
      "GEMINI_CLI",
      "GOOGLE_GEMINI_CLI"
    ],
    "codex": [
      "CODEX_HOME",
      "OPENAI_CODEX"
    ]
  },
  "parent_process_patterns": {
    "claude": [
      "claude",
      "claude-*",
      "*claude*"
    ],
    "grok": [
      "grok",
      "grok-*",
      "*grok*"
    ],
    "gemini": [
      "gemini",
      "gemini-*",
      "*gemini*"
    ],
    "codex": [
      "codex",
      "codex-*",
      "*codex*"
    ],
    "opencode": [
      "opencode",
      "opencode-*"
    ],
    "cline": [
      "cline",
      "cline-*"
    ],
    "kimi": [
      "kimi",
      "kimi-*"
    ],
    "kiro": [
      "kiro",
      "kiro-*"
    ]
  },
  "cascade_scan_order": [
    "grok",
    "claude",
    "gemini",
    "cline",
    "opencode",
    "kimi",
    "kiro",
    "codex"
  ],
  "generation": {
    "context_mode": "deterministic",
    "include_xml_template": true,
    "include_principles": true,
    "include_chaining": true,
    "include_examples": true,
    "include_system_prompt": true,
    "system_prompt_path": "assets/generation-agent-prompt.md",
    "xml_template_path": "references/xml-template.md",
    "principles_path": "references/prompting-principles.md",
    "chaining_path": "references/prompt-chaining.md",
    "examples_path": "examples/before-after.md",
    "extra_reference_paths": [],
    "output_instructions": "Output ONLY the final improved XML prompt. No explanation, no code fences, no commentary, no execution of the request.",
    "require_xml_output": true,
    "forbid_agent_codebase_search": true
  }
}
